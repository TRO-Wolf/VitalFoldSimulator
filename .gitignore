*.parquet
*.arrow
*.ipc
*.csv
*.json
# Re-allow schema/fixture JSON if needed:
!health_clinic_schema.sql

# ─── IDE & Editor ─────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml
*.swp
*.swo
*~

