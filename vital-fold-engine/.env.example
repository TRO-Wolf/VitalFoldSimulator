# VitalFold Engine - Environment Configuration Template
# Copy this file to .env and update values for your environment

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────

# HTTP server bind address
HOST=127.0.0.1

# HTTP server port
PORT=8787

# ─────────────────────────────────────────────────────────────────────────────
# Aurora DSQL Database Configuration
# ─────────────────────────────────────────────────────────────────────────────

# DSQL cluster endpoint (hostname only — port is always 5432)
DSQL_CLUSTER_ENDPOINT=your-cluster-id.dsql.us-east-1.on.aws

# AWS region where DSQL cluster is deployed
DSQL_REGION=us-east-1

# Database name to use
DSQL_DB_NAME=postgres

# Database user for authentication
DSQL_USER=admin

# Maximum number of connections in the pool
DB_POOL_SIZE=10

# ─────────────────────────────────────────────────────────────────────────────
# JWT Authentication Configuration
# ─────────────────────────────────────────────────────────────────────────────

# JWT signing secret (must be at least 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long-change-this

# JWT token expiration time in hours
JWT_EXPIRY_HOURS=24

# ─────────────────────────────────────────────────────────────────────────────
# Admin Authentication
# ─────────────────────────────────────────────────────────────────────────────

# Admin login credentials for POST /api/v1/auth/admin-login
# If not set, admin login is disabled.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# ─────────────────────────────────────────────────────────────────────────────
# Static Files (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Override the directory for frontend static files.
# Default: compiled-in path to vital-fold-engine/static/
# STATIC_DIR=/path/to/static

# ─────────────────────────────────────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Rust log filter (RUST_LOG environment variable)
# Levels: error, warn, info, debug, trace
RUST_LOG=vital_fold_engine=info,actix_web=info,sqlx=warn

# ─────────────────────────────────────────────────────────────────────────────
# AWS Credentials (Optional - for IAM database authentication)
# ─────────────────────────────────────────────────────────────────────────────

# If using IAM database authentication, set AWS credentials:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=optional-session-token-for-temporary-credentials

# Or use AWS credential provider chain (recommended):
# - IAM roles (if running on EC2)
# - ECS task role (if running in ECS)
# - AWS profiles in ~/.aws/credentials
# - Environment variables

# ─────────────────────────────────────────────────────────────────────────────
# SQLx Configuration (Development Only)
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL for sqlx compile-time checking (development only)
# This is not used at runtime, only for cargo check/build
# DATABASE_URL=postgres://postgres:password@localhost:5432/vital_fold_dev
